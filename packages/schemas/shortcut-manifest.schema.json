{
	"$id": "https://shortcuts.dev/schemas/shortcut-manifest.schema.json",
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Shortcut Manifest",
	"type": "object",
	"additionalProperties": true,
	"required": [
		"id",
		"name",
		"version",
		"summary",
		"category",
		"status",
		"license",
		"maintainers",
		"source",
		"declared_permissions"
	],
	"properties": {
		"id": {
			"type": "string",
			"pattern": "^[a-z0-9][a-z0-9.-]+$"
		},
		"name": {
			"type": "string",
			"minLength": 1
		},
		"version": {
			"type": "string",
			"pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
		},
		"summary": {
			"type": "string",
			"minLength": 1
		},
		"category": {
			"type": "string",
			"minLength": 1
		},
		"status": {
			"enum": ["experimental", "stable", "deprecated", "archived"]
		},
		"license": {
			"type": "string",
			"minLength": 1
		},
		"maintainers": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"required": ["name"],
				"properties": {
					"name": {
						"type": "string",
						"minLength": 1
					}
				},
				"additionalProperties": true
			}
		},
		"compatibility": {
			"type": "object"
		},
		"source": {
			"type": "object",
			"required": ["mode"],
			"properties": {
				"mode": {
					"enum": ["manual", "artifact", "cherri", "jelly"]
				},
				"entrypoint": {
					"type": ["string", "null"]
				}
			},
			"additionalProperties": true
		},
		"declared_permissions": {
			"type": "object"
		},
		"security": {
			"type": "object"
		},
		"tests": {
			"type": "object"
		},
		"release": {
			"type": "object"
		}
	}
}
