{
	"$id": "https://shortcuts.dev/schemas/shortcut-manifest.schema.json",
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Shortcut Manifest",
	"type": "object",
	"additionalProperties": true,
	"required": [
		"id",
		"name",
		"version",
		"summary",
		"category",
		"status",
		"license",
		"maintainers",
		"source",
		"declared_permissions",
		"tests"
	],
	"properties": {
		"id": {
			"type": "string",
			"pattern": "^[a-z0-9][a-z0-9.-]+$"
		},
		"name": {
			"type": "string",
			"minLength": 1
		},
		"version": {
			"type": "string",
			"pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
		},
		"summary": {
			"type": "string",
			"minLength": 1
		},
		"category": {
			"type": "string",
			"minLength": 1
		},
		"status": {
			"enum": ["experimental", "stable", "deprecated", "archived"]
		},
		"license": {
			"type": "string",
			"minLength": 1
		},
		"maintainers": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"required": ["name"],
				"properties": {
					"name": {
						"type": "string",
						"minLength": 1
					}
				},
				"additionalProperties": true
			}
		},
		"compatibility": {
			"type": "object"
		},
		"source": {
			"type": "object",
			"required": ["mode"],
			"properties": {
				"mode": {
					"enum": ["manual", "artifact", "cherri", "jelly"]
				},
				"entrypoint": {
					"type": ["string", "null"]
				}
			},
			"additionalProperties": true
		},
		"declared_permissions": {
			"type": "object"
		},
		"icon": {
			"type": "object",
			"required": ["path"],
			"properties": {
				"path": {
					"type": "string",
					"pattern": "^(?!/)(?!.*(^|/)\\.\\.(/|$)).+\\.png$"
				},
				"alt": {
					"type": "string",
					"minLength": 1
				}
			},
			"additionalProperties": true
		},
		"html_runtime": {
			"type": "object",
			"properties": {
				"profiles": {
					"type": "array",
					"items": {
						"type": "object",
						"required": ["id", "support"],
						"properties": {
							"id": {
								"enum": ["hosted", "local-bundled"]
							},
							"support": {
								"enum": ["supported", "constrained", "unsupported"]
							},
							"provider": {
								"type": "string"
							},
							"entrypoint": {
								"type": "string"
							},
							"output": {
								"type": "string"
							},
							"notes": {
								"type": "string"
							}
						},
						"additionalProperties": true
					}
				},
				"size_gates": {
					"type": "object"
				}
			},
			"additionalProperties": true
		},
		"security": {
			"type": "object"
		},
		"tests": {
			"type": "object",
			"properties": {
				"static": {
					"type": "object"
				},
				"runtime": {
					"type": "object",
					"properties": {
						"enabled": {
							"type": "boolean"
						}
					},
					"additionalProperties": true
				},
				"manual": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "string",
						"pattern": "\\S"
					}
				}
			},
			"allOf": [
				{
					"if": {
						"not": {
							"required": ["runtime"],
							"properties": {
								"runtime": {
									"required": ["enabled"],
									"properties": {
										"enabled": {
											"const": true
										}
									}
								}
							}
						}
					},
					"then": {
						"required": ["manual"]
					}
				}
			],
			"additionalProperties": true
		},
		"release": {
			"type": "object"
		}
	}
}
