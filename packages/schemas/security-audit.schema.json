{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "Security Audit",
	"type": "object",
	"required": [
		"package_id",
		"actiondb_version",
		"strict",
		"passed",
		"findings"
	],
	"properties": {
		"package_id": { "type": "string" },
		"actiondb_version": { "type": "string" },
		"strict": { "type": "boolean" },
		"passed": { "type": "boolean" },
		"summary": { "type": "object" },
		"findings": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["id", "title", "severity", "status", "detail"],
				"additionalProperties": true
			}
		}
	}
}
