{
	"name": "@shortcuts/docs",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "eslint . --max-warnings=0",
		"typecheck": "tsc --noEmit",
		"generate": "fumadocs-mdx",
		"generate:refs": "shortcutkit docs generate --docs-root apps/docs",
		"check:generated": "shortcutkit docs generate --docs-root apps/docs --check",
		"prebuild": "pnpm generate"
	},
	"dependencies": {
		"@types/mdx": "latest",
		"fumadocs-core": "latest",
		"fumadocs-mdx": "latest",
		"fumadocs-ui": "latest",
		"lucide-react": "latest",
		"next": "^16.0.0",
		"next-themes": "latest",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "latest",
		"@types/node": "latest",
		"@types/react": "latest",
		"@types/react-dom": "latest",
		"eslint": "^9.39.1",
		"eslint-config-next": "latest",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.9.0"
	}
}
